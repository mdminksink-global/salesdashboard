# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (optional) — PUBLIC VAPID key only. Generate with:  npx web-push generate-vapid-keys
# The PRIVATE key must NOT go here — set it as a Supabase secret (see supabase/functions/send-push).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
